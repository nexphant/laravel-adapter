{
    "name": "nexphant/laravel-adapter",
    "description": "Laravel HTTP server adapter for the Nexphant runtime.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "nexphant/server": "^0.0",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Nexphant\\LaravelAdapter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexphant\\LaravelAdapter\\NexphantServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
