{
    "name": "nexph/laravel-adapter",
    "description": "Laravel HTTP server adapter for the Nexph runtime.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "nexph/server": "^0.0",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Nexph\\LaravelAdapter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexph\\LaravelAdapter\\NexphServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
